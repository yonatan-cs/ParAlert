# Copy to .env.local for dev, or set in Vercel project settings for prod.
# Base URL of the FS-A backend. WS URL is derived (http->ws, https->wss).
# Local dev default (if unset): http://localhost:8000
# Production (set in Vercel project settings): VITE_API_BASE=https://safenet-backend-cnmy.onrender.com
VITE_API_BASE=http://localhost:8000
